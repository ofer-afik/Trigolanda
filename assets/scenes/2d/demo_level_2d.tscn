[node name="TextBox" parent="TextBoxes" unique_id=630697749 instance=ExtResource("6_pa72e")]
z_index = 1
offset_left = -3157.0
offset_top = -1077.0
offset_right = -1950.0
offset_bottom = -896.0
text = "[emph]Wait![/emph] Before you start, a bit of info. When you finish reading, press jump so textboxes will disappear and you will see what is above you..."

[node name="TextBox2" parent="TextBoxes" unique_id=826287025 instance=ExtResource("6_pa72e")]
z_index = 1
offset_left = -2817.0
offset_top = -859.0
offset_right = -2173.0
offset_bottom = -678.0
text = "The green [emph]SoulCry[/emph] crystal stores a bit of your soul, so you can regenerate."

[node name="TextBox3" parent="TextBoxes" unique_id=261945285 instance=ExtResource("6_pa72e")]
z_index = 1
offset_left = -3178.0
offset_top = -663.0
offset_right = -2183.0
offset_bottom = -438.0
text = "You might also see purple crystals here - they're the [emph]GravFlip[/emph] crystals. Whoever named the crystals (native plants in this multiverse) really wasn't very creative"

[node name="TextBox5" parent="TextBoxes" unique_id=43315857 instance=ExtResource("6_pa72e")]
z_index = 1
offset_left = -3197.0
offset_top = -364.0
offset_right = -2431.0
offset_bottom = -194.0
text = "These bushes are what crystals grow on. Be careful, the bushes are [emph]poisonous[/emph]!"

[node name="TextBox4" parent="TextBoxes" unique_id=845550480 instance=ExtResource("6_pa72e")]
z_index = 1
offset_left = -2395.0
offset_top = -378.0
offset_right = -1400.0
offset_bottom = -189.0
text = "This is just a demo section - instead of the full world you must explore to find a home, just get to the trophy"

